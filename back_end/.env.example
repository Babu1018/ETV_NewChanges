# PostgreSQL — create database "ETV" in pgAdmin
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@localhost:5432/ETV

# Shared API key (must match frontend VITE_API_AUTH_KEY)
API_AUTH_KEY=your-api-key

# Sarvam cloud (Hindi/Telugu ASR + TTS)
SARVAM_API_KEY=sk_your_key

# JWT auth
AUTH_JWT_SECRET=change-me-etv-jwt-secret
AUTH_TOKEN_HOURS=24

# Optional: password-reset email
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=

# Hugging Face token — required for gated IndicConformer ground-truth model
# (request access: https://huggingface.co/ai4bharat/indic-conformer-600m-multilingual)
# Also used by English Whisper / OmniVoice when needed.
# HF_TOKEN=hf_your_token
HF_HUB_DISABLE_SYMLINKS=1
